@baseUrl = http://localhost:3000

### Test endpoint
GET {{baseUrl}}/test

### Set fields endpoint
GET {{baseUrl}}/set/fields/1

### Get all users
GET {{baseUrl}}/users

### Get a user by ID
GET {{baseUrl}}/users/1

### Create a user (valid)
### @name CreateUser
POST {{baseUrl}}/users
Content-Type: application/json

{
  "username": "trung_{{$timestamp}}",
  "email": "trung_{{$timestamp}}@otmc.com.vn",
  "content": {"key": "value"},
  "enabled": true,
  "test_int": 34132,
  "test_string_array": ["string1", "string2"],
  "test_int_array": [1, 2, 3],
  "test_map": {"key1": 1, "key2": 2},
  "test_json": {"nested": {"key": "value"}},
  "profile": {"bio": "Senior Developer"}
}

### Update a user (valid)
PATCH {{baseUrl}}/users/1
Content-Type: application/json

{
  "email": "trung_updated@otmc.com.vn",
  "content": "{\"test\": \"updated\"}"
}

### Delete a user (valid)
DELETE {{baseUrl}}/users/3

### Create a user (missing username -> validation error)
POST {{baseUrl}}/users
Content-Type: application/json

{
  "email": "trung@otmc.dev"
}

### Create a user (invalid email -> validation error)
POST {{baseUrl}}/users
Content-Type: application/json

{
  "username": "trung",
  "email": "not-an-email"
}